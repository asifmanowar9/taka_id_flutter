# Copy this to .env and fill in your values
PORT=3000

# ── Supabase ───────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API → "Publishable and secret API keys"
SUPABASE_URL=https://your-project-id.supabase.co

# Use the SECRET key on the backend — it bypasses RLS (never expose to client).
SUPABASE_SECRET_KEY=ysb_secret_qf5onENesgwuF-BGmXuoKg_IGU09mKz

# Name of the Supabase Storage bucket for banknote images.
# Create it in: Dashboard → Storage → New bucket → name: banknotes → Public ✓
SUPABASE_STORAGE_BUCKET=banknotes

